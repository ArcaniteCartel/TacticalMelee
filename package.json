{
  "name": "tactical-melee",
  "version": "0.1.0",
  "description": "TTRPG combat management system",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "com.tacticalmelee.app",
    "productName": "TacticalMelee",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^3.0.0",
    "@mantine/core": "^7.0.0",
    "@mantine/hooks": "^7.0.0",
    "@tabler/icons-react": "^3.41.1",
    "bufferutil": "^4.1.0",
    "express": "^4.18.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.20.0",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.0",
    "postcss-preset-mantine": "^1.13.0",
    "postcss-simple-vars": "^7.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
